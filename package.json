{
  "name": "markov-keyboard",
  "version": "1.0.0",
  "description": "Prédiction de saisie au clavier par modèle de Markov — suggestion de mot suivant et autocomplétion en temps réel.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
